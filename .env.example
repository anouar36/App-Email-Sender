# Environment Variables Template
# Copy this to .env and fill in your actual values

# Database
DATABASE_URL=sqlite:./email_sender.db

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (for app email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Server Configuration
PORT=10000
NODE_ENV=production

# Frontend URL (will be your Render static site URL)
FRONTEND_URL=https://your-frontend-app-name.onrender.com

# Backend URL (will be your Render web service URL)
BACKEND_URL=https://your-backend-app-name.onrender.com
